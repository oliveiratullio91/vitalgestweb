rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyWebUserFields() {
      return request.resource.data.keys().hasOnly([
        'name',
        'email',
        'createdAt',
        'donations',
        'appointments'
      ]);
    }

    function emailMatchesAuth() {
      return request.resource.data.email == request.auth.token.email;
    }

    match /hemocentros/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /usuarios/{userId} {
      allow read, write: if isOwner(userId);

      match /agendamentos/{agendamentoId} {
        allow read, write: if isOwner(userId);
      }

      match /{subCollection}/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // INICIO DA CORRECAO - regras seguras para usuarios do app web
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && hasOnlyWebUserFields() && emailMatchesAuth();
      allow delete: if false;
    }
    // FIM DA CORRECAO - regras seguras para usuarios do app web

    match /appointments/{appointmentId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.userUid;
    }

    match /publico/{document=**} {
      allow read: if true;
    }
  }
}
